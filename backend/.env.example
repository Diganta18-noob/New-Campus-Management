# CORS Configuration
# Add your frontend URL(s) here
CORS_ORIGIN=http://localhost:3000

# MongoDB Connection
# Replace with your MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/your_database_name

# Node Environment
# Options: development, production, test
NODE_ENV=development

# JWT Configuration
# Replace with a strong, unique secret key (use a secure random string generator)
JWT_SECRET=your_jwt_secret_key_here
# Token expiration time (e.g., 1h, 7d, 30d)
JWT_EXPIRE=7d

# Bcrypt Salt Rounds
# Recommended: 10-12 for production (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10
